# Supabase 配置
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# AI 服务 API 密钥
AI_API_KEY=your-ai-api-key

# 服务器端口（仅本地开发使用）
PORT=3001

# 外部视频处理 Worker 地址
WORKER_BASE_URL=https://your-worker-service.example.com

# Webhook 回调地址（Worker 完成后回调）
WEBHOOK_BASE_URL=https://your-api-domain.vercel.app
